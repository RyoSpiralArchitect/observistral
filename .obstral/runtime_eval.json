{
  "version": 1,
  "defaults": {
    "tool_root": ".",
    "lang": "en",
    "max_iters": 8,
    "copy_tool_root": false
  },
  "cases": [
    {
      "id": "slash-realize-command",
      "tags": ["tui", "prefs", "slash"],
      "prompt": "Locate where the /realize slash command is handled in the TUI. Do not edit anything. Use tools as needed. Final answer must include the file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/tui/events.rs" }
      ]
    },
    {
      "id": "pane-prefs-storage",
      "tags": ["tui", "prefs"],
      "prompt": "Find where pane-scoped TUI preferences are serialized and restored. Do not edit anything. Final answer must include the main file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/tui/prefs.rs" }
      ]
    },
    {
      "id": "repo-map-read-file-fallback",
      "tags": ["repo-map", "coder", "fallback"],
      "prompt": "Find where the coder-side repo-map fallback for read_file misses is wired into the TUI agent flow. Do not edit anything. Final answer must include the file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/tui/agent.rs" }
      ]
    },
    {
      "id": "sandbox-config-alias-loading",
      "tool_root": "tests/fixtures/mini-rust-cli",
      "tags": ["sandbox", "rust", "config", "read-only"],
      "prompt": "Locate where project-local profile aliases are loaded for the greet command. Do not edit anything. Final answer must include the main file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/config.rs" }
      ]
    },
    {
      "id": "create-single-file",
      "tool_root": "tests/fixtures/runtime-create-file",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "create", "file"],
      "prompt": "Create `notes/todo.txt` containing exactly `ship it`. Verify it before you finish. Final answer must include the created file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "write_file" },
        { "kind": "assistant_contains", "value": "notes/todo.txt" },
        { "kind": "trace_event_seen", "event": "task_harness" }
      ]
    },
    {
      "id": "init-repo-artifact",
      "tool_root": "tests/fixtures/runtime-init-repo",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "repo", "init"],
      "prompt": "Create a new git repo in `demo_repo/` with a README.md and `.gitignore`. Verify those artifacts before you finish. Final answer must include the repo path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "exec" },
        { "kind": "tool_call_seen", "name": "write_file" },
        { "kind": "assistant_contains", "value": "demo_repo" },
        { "kind": "assistant_contains", "value": ".gitignore" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "meta_harness_policy" }
      ]
    },
    {
      "id": "fix-failing-rust-test",
      "tool_root": "tests/fixtures/runtime-fix-rust",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "fix", "rust", "tests"],
      "prompt": "Fix the failing test with the smallest code change. Run tests before you finish. Final answer must include the changed file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "tool_call_seen", "name": "patch_file" },
        { "kind": "trace_event_seen", "event": "task_harness" }
      ]
    }
  ]
}
