{
  "version": 1,
  "defaults": {
    "tool_root": ".",
    "lang": "en",
    "max_iters": 8,
    "copy_tool_root": false
  },
  "cases": [
    {
      "id": "slash-realize-command",
      "tags": ["tui", "prefs", "slash"],
      "prompt": "Locate where the /realize slash command is handled in the TUI. Do not edit anything. Use tools as needed. Final answer must include the file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/tui/events.rs" }
      ]
    },
    {
      "id": "pane-prefs-storage",
      "tags": ["tui", "prefs"],
      "prompt": "Find where pane-scoped TUI preferences are serialized and restored. Do not edit anything. Final answer must include the main file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/tui/prefs.rs" }
      ]
    },
    {
      "id": "repo-map-read-file-fallback",
      "tags": ["repo-map", "coder", "fallback"],
      "prompt": "Find where the coder-side repo-map fallback for read_file misses is wired into the TUI agent flow. Do not edit anything. Final answer must include the file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/tui/agent.rs" }
      ]
    },
    {
      "id": "sandbox-config-alias-loading",
      "tool_root": "tests/fixtures/mini-rust-cli",
      "tags": ["sandbox", "rust", "config", "read-only"],
      "prompt": "Locate where project-local profile aliases are loaded for the greet command. Do not edit anything. Final answer must include the main file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "assistant_contains", "value": "src/config.rs" }
      ]
    },
    {
      "id": "create-single-file",
      "tool_root": "tests/fixtures/runtime-create-file",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "create", "file"],
      "prompt": "Create `notes/todo.txt` containing exactly `ship it`. Verify it before you finish. Final answer must include the created file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "write_file" },
        { "kind": "assistant_contains", "value": "notes/todo.txt" },
        { "kind": "trace_event_seen", "event": "task_harness" }
      ]
    },
    {
      "id": "init-repo-artifact",
      "tool_root": "tests/fixtures/runtime-init-repo",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "repo", "init"],
      "prompt": "Create a new git repo in `demo_repo/` with a README.md and `.gitignore`. Verify those artifacts before you finish. Final answer must include the repo path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "exec" },
        { "kind": "tool_call_seen", "name": "write_file" },
        { "kind": "assistant_contains", "value": "demo_repo" },
        { "kind": "assistant_contains", "value": ".gitignore" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "meta_harness_policy" },
        { "kind": "trace_event_seen", "event": "evaluator_loop" },
        { "kind": "trace_event_seen", "event": "harness_evolution_loaded" },
        { "kind": "trace_event_seen", "event": "harness_evolution_patch_proposed" },
        { "kind": "trace_event_seen", "event": "harness_evolution_overlay_prompted" },
        { "kind": "tool_root_file_exists", "path": ".obstral/governor_contract.overlay.json" }
      ]
    },
    {
      "id": "fix-failing-rust-test",
      "tool_root": "tests/fixtures/runtime-fix-rust",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "fix", "rust", "tests"],
      "prompt": "Fix the failing test with the smallest code change. Run tests before you finish. Final answer must include the changed file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "tool_call_seen", "name": "patch_file" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "harness_evolution_loaded" },
        { "kind": "trace_event_seen", "event": "progress_state_loaded" },
        { "kind": "trace_event_seen", "event": "progress_bridge_prompted" },
        { "kind": "tool_root_file_exists", "path": ".obstral/progress.json" }
      ]
    },
    {
      "id": "resume-session-bridge-fix",
      "tool_root": "tests/fixtures/runtime-fix-rust",
      "session_seed": "session_bridge_resume_seed.json",
      "copy_tool_root": true,
      "max_iters": 6,
      "tags": ["action", "resume", "session", "bridge", "rust"],
      "prompt": "Continue from the previous session state. Finish the smallest safe fix and run tests before you finish. Final answer must include the changed file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "trace_event_seen", "event": "session_bridge_prompted" },
        { "kind": "trace_event_seen", "event": "progress_bridge_prompted" },
        { "kind": "tool_call_seen", "name": "patch_file" },
        { "kind": "assistant_contains", "value": "src/lib.rs" },
        { "kind": "tool_root_file_exists", "path": ".obstral/progress.json" }
      ]
    },
    {
      "id": "fix-rust-maze-wall-bug",
      "tool_root": "tests/fixtures/runtime-fix-rust-medium",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "fix", "rust", "tests", "medium"],
      "prompt": "Fix the failing maze movement test with the smallest safe code change. Run tests before you finish. Final answer must include the changed file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "tool_call_seen", "name": "patch_file" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "harness_evolution_loaded" },
        { "kind": "trace_event_seen", "event": "progress_state_loaded" },
        { "kind": "assistant_contains", "value": "src/maze.rs" },
        { "kind": "assistant_contains", "value": "cargo test 2>&1" },
        { "kind": "tool_root_file_exists", "path": ".obstral/progress.json" }
      ]
    },
    {
      "id": "fix-rust-binary-heading-bug",
      "tool_root": "tests/fixtures/runtime-fix-rust-binary-medium",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "fix", "rust", "tests", "medium", "binary"],
      "prompt": "Fix the failing robot heading turn test with the smallest safe code change. Run tests before you finish. Final answer must include the changed file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "tool_call_seen", "name": "patch_file" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "harness_evolution_loaded" },
        { "kind": "trace_event_seen", "event": "progress_state_loaded" },
        { "kind": "assistant_contains", "value": "src/main.rs" },
        { "kind": "assistant_contains", "value": "cargo test 2>&1" },
        { "kind": "tool_root_file_exists", "path": ".obstral/progress.json" }
      ]
    },
    {
      "id": "fix-rust-binary-module-heading-bug",
      "tool_root": "tests/fixtures/runtime-fix-rust-binary-module-medium",
      "copy_tool_root": true,
      "max_iters": 14,
      "tags": ["action", "fix", "rust", "tests", "medium", "binary", "stretch"],
      "prompt": "Fix the failing robot heading turn test with the smallest safe code change. Run tests before you finish. Final answer must include the changed file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "read_file" },
        { "kind": "tool_call_seen", "name": "patch_file" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "harness_evolution_loaded" },
        { "kind": "trace_event_seen", "event": "progress_state_loaded" },
        { "kind": "assistant_contains", "value": "src/robot.rs" },
        { "kind": "assistant_contains", "value": "cargo test 2>&1" },
        { "kind": "tool_root_file_exists", "path": ".obstral/progress.json" }
      ]
    },
    {
      "id": "maze-game-rust-repo",
      "tool_root": "tests/fixtures/runtime-maze-game",
      "copy_tool_root": true,
      "max_iters": 16,
      "tags": ["action", "repo", "scaffold", "rust", "maze"],
      "prompt": "Create a new git repo in `maze_game/` for a tiny Rust maze game. Keep the project minimal: add a README.md with controls, put the gameplay logic in `maze_game/src/lib.rs`, keep `maze_game/src/main.rs` runnable, and include at least one unit test that passes under `cd maze_game && cargo test 2>&1`. Final answer must include the repo path and the main gameplay file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "exec" },
        { "kind": "tool_call_seen", "name": "write_file" },
        { "kind": "assistant_contains", "value": "maze_game/" },
        { "kind": "assistant_contains", "value": "maze_game/src/lib.rs" },
        { "kind": "assistant_contains", "value": "maze_game/src/main.rs" },
        { "kind": "assistant_contains", "value": "cargo test 2>&1" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "harness_evolution_loaded" }
      ]
    },
    {
      "id": "maze-game-pygame-repo",
      "tool_root": "tests/fixtures/runtime-maze-game-pygame",
      "copy_tool_root": true,
      "max_iters": 18,
      "tags": ["action", "repo", "scaffold", "python", "pygame", "maze"],
      "prompt": "Create a new git repo in `maze_game_pygame/` for a tiny pygame maze game. Keep the project minimal: add a README.md with controls, put the gameplay logic in `maze_game_pygame/game.py`, keep `maze_game_pygame/main.py` runnable, and include at least one unit test that passes under `cd maze_game_pygame && SDL_VIDEODRIVER=dummy python3 -m unittest -q 2>&1`. Final answer must include the repo path and the main gameplay file path.",
      "checks": [
        { "kind": "completed" },
        { "kind": "error_free" },
        { "kind": "tool_call_seen", "name": "exec" },
        { "kind": "tool_call_seen", "name": "write_file" },
        { "kind": "assistant_contains", "value": "maze_game_pygame/" },
        { "kind": "assistant_contains", "value": "maze_game_pygame/game.py" },
        { "kind": "assistant_contains", "value": "maze_game_pygame/main.py" },
        { "kind": "assistant_contains", "value": "SDL_VIDEODRIVER=dummy python3 -m unittest -q 2>&1" },
        { "kind": "trace_event_seen", "event": "task_harness" },
        { "kind": "trace_event_seen", "event": "harness_evolution_loaded" }
      ]
    }
  ]
}
